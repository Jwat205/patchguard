# Application
APP_NAME=patchguard
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# GitHub Integration
GITHUB_TOKEN=your_github_token_here
GITHUB_WEBHOOK_SECRET=your_webhook_secret_here

# Anthropic/Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# PostgreSQL
DATABASE_URL=postgresql://patchguard:patchguard@localhost:5432/patchguard
POSTGRES_USER=patchguard
POSTGRES_PASSWORD=patchguard
POSTGRES_DB=patchguard

# MongoDB
MONGODB_URL=mongodb://localhost:27017
MONGODB_DB=patchguard

# Redis
REDIS_URL=redis://localhost:6379
REDIS_DB=0

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_PR_EVENTS=pr-events
KAFKA_TOPIC_REVIEW_RESULTS=review-results
KAFKA_CONSUMER_GROUP=patchguard-consumers

# API Server
HOST=0.0.0.0
PORT=8000

# OpenTelemetry (optional)
OTEL_SERVICE_NAME=patchguard
OTEL_EXPORTER_JAEGER_ENDPOINT=http://localhost:14268/api/traces
